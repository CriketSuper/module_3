# CUPS server and queue names.
CUPS_SERVER_HOST=hq-srv.au-team.irpo
CUPS_SERVER_PORT=631
SERVER_QUEUE=Cups-PDF
CLIENT_QUEUE=HQ-PDF

# Test print.
TEST_DOCUMENT=/tmp/hq-pdf-test.txt

# Export the latest generated PDF to the NFS share.
NFS_EXPORT_DIR=/raid/nfs
EXPORTED_PDF_NAME=Print.pdf
EXPORTED_PDF_MODE=0666
PDF_WAIT_SECONDS=30
